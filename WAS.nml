    running_cost_factor: Boeing_737_100_running_cost_factor;
    sound_effect: Boeing_737_100_sound_effect;

    cost_factor: 29;
    purchase_running_cost_factor: 64;
    purchase_speed: int(878*5/64);
  }
}

