  8..12: return 34 *50/100 ; 13..15: return 34 *1 ; 18: return 34 *88/100 ; 16..20: return 34 *91/100 ; 21..22: return 34 *95/100 ; return 34 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ100ER_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(249*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(386*5/64); // airplane climbing after take-off
      18: return int(814*5/64); // heading for tower contact point
  16..20: return int(322*5/64); // in flight
  21..22: return int(217*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

