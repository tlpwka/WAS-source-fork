    running_cost_factor: Bombardier_Dash_8_400Q_running_cost_factor;
    sound_effect: Bombardier_Dash_8_400Q_sound_effect;

    cost_factor: 22;
    purchase_running_cost_factor: 35;
    purchase_speed: int(668*5/64);
  }
}

