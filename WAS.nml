switch (FEAT_AIRCRAFT, SELF, Airbus_A318_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 90 *50/100 ; 13..15: return 90 *1 ; 18: return 90 *88/100 ; 16..20: return 90 *91/100 ; 21..22: return 90 *95/100 ; return 90 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A318_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(241*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(346*5/64); // airplane climbing after take-off
      18: return int(854*5/64); // heading for tower contact point
  16..20: return int(451*5/64); // in flight
  21..22: return int(217*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A318_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_AIRBUS);
  1: string(STR_VLIV_AIR_FRANCE);
  2: string(STR_VLIV_AVIANCA);
  3: string(STR_VLIV_BRITISH_AIRWAYS_UNION_FLAG);
  4: string(STR_VLIV_FRONTIER_AIRLINES);
  5: string(STR_VLIV_LAN_AIRLINES);
  6: string(STR_VLIV_TAROM);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A318_cargo_subtype_capacity, cargo_subtype)
{
   1: return 120;
   2: return 100;
   3: return 32;
   4: return 114;
   5: return 126;
   6: return 113;
   return 107;
}

item (FEAT_AIRCRAFT, Airbus_A318)
{
  property
  {
