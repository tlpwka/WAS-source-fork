    Embraer_E195AR_Greyscale;
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E195AR_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 61 *50/100 ; 13..15: return 61 *1 ; 18: return 61 *88/100 ; 16..20: return 61 *91/100 ; 21..22: return 61 *95/100 ; return 61 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E195AR_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(241*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(410*5/64); // airplane climbing after take-off
      18: return int(886*5/64); // heading for tower contact point
  16..20: return int(427*5/64); // in flight
  21..22: return int(273*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E195AR_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E195AR_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_EMBRAER);
  1: string(STR_VLIV_ROYAL_JORDANIAN);
  2: string(STR_VLIV_TAP);
       return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E195AR_cargo_subtype_capacity, cargo_subtype)
{
  1: return 100; // Royal Jordanian
  2: return 118; // TAP
     return 118;
}

item (FEAT_AIRCRAFT, Embraer_E195AR)
{
  property
  {
    name: string(STR_AIRV_EMBRAER_ERJ_195AR);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(2006 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 2259 >= 2050 ? VEHICLE_NEVER_EXPIRES : (2006 -2259 -2 < retire_early_default ? 2259 -2006 +2 : -retire_early_default);
    retire_early: 2006 -2259 -2 < retire_early_default ? retire_early_default+1 : 2006 -2259 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 18;
    passenger_capacity: 118;
    mail_capacity: 12;
    acceleration: 27; // in 27,75 mph/day
    range: 735;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Embraer_E195AR_sprites;
    purchase: Embraer_E195AR_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Embraer_E195AR_cargo_subtype_text;
 passenger_capacity: Embraer_E195AR_cargo_subtype_capacity;
    speed: Embraer_E195AR_speed;
    running_cost_factor: Embraer_E195AR_running_cost_factor;
    sound_effect: Embraer_E195AR_sound_effect;

    cost_factor: 37;
    purchase_running_cost_factor: 61;
    purchase_speed: int(886*5/64);
  }
}

if (Ranges == 0)
{
  item (FEAT_AIRCRAFT, Embraer_E195AR)
