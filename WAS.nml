switch (FEAT_AIRCRAFT, SELF, Boeing_747_300M_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 229 *50/100 ; 13..15: return 229 *1 ; 18: return 229 *88/100 ; 16..20: return 229 *91/100 ; 21..22: return 229 *95/100 ; return 229 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_747_300M_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(289*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(435*5/64); // airplane climbing after take-off
      18: return int(999*5/64); // heading for tower contact point
  16..20: return int(443*5/64); // in flight
  21..22: return int(265*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Boeing_747_300M_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_747_300M_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_BOEING);
  1: string(STR_VLIV_MAHAN_AIR);
  2: string(STR_VLIV_SURINAM_AIRWAYS);
     return CB_RESULT_NO_TEXT;
}

item (FEAT_AIRCRAFT, Boeing_747_300M)
{
  property
  {
    name: string(STR_AIRV_BOEING_747_300M);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1983 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 1990 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1983 -1990 -2 < retire_early_default ? 1990 -1983 +2 : -retire_early_default);
    retire_early: 1983 -1990 -2 < retire_early_default ? retire_early_default+1 : 1983 -1990 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 74;
    passenger_capacity: 245;
    mail_capacity: 255;
    acceleration: 27; // in 27,75 mph/day
    range: 2165;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Boeing_747_300M_sprites;
    purchase: Boeing_747_300M_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Boeing_747_300M_cargo_subtype_text;
    speed: Boeing_747_300M_speed;
    running_cost_factor: Boeing_747_300M_running_cost_factor;
    sound_effect: Boeing_747_300M_sound_effect;

    cost_factor: 274;
    purchase_running_cost_factor: 229;
    purchase_speed: int(999*5/64);
 mail_capacity: return 640;
    purchase_mail_capacity: return 640;
  }
}

