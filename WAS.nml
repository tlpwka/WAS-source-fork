switch (FEAT_AIRCRAFT, SELF, ATR_42_300_sprites, cargo_subtype)
{
  1: ATR_42_300_AerLingusRegional;
  2: ATR_42_300_AirSouthwest;
  3: ATR_42_300_AurignyAirService;
  4: ATR_42_300_Finnair;
  5: ATR_42_300_HighlandExpress;
  6: ATR_42_300_UTair;
     ATR_42_300_Greyscale;
}

switch (FEAT_AIRCRAFT, SELF, ATR_42_300_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 51 *50/100 ; 13..15: return 51 *1 ; 18: return 51 *88/100 ; 16..20: return 51 *91/100 ; 21..22: return 51 *95/100 ; return 51 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, ATR_42_300_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(241*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(346*5/64); // airplane climbing after take-off
      18: return int(491*5/64); // heading for tower contact point
  16..20: return int(338*5/64); // in flight
  21..22: return int(209*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

