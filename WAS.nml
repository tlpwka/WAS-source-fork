  8..12: return 139 *50/100 ; 13..15: return 139 *1 ; 18: return 139 *88/100 ; 16..20: return 139 *91/100 ; 21..22: return 139 *95/100 ; return 139 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Lockheed_L049_Constellation_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(241*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(370*5/64); // airplane climbing after take-off
      18: return int(504*5/64); // heading for tower contact point
  16..20: return int(418*5/64); // in flight
  21..22: return int(257*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

