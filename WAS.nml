switch (FEAT_AIRCRAFT, SELF, Airbus_A310_200_cargo_subtype_capacity, cargo_subtype)
{
   1: return 218; // AirAlgerie
   2: return 164; // AirFrance
   5: return 265; // Condor
   7: return 271; // HapagLloyd
   8: return 212; // IranAir
  10: return 201; // PamAm
  12: return 255; // S7
  13: return 183; // Singapore
  14: return 208; // Swiss
