switch (FEAT_AIRCRAFT, SELF, BAC_1_11_400_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 53 *50/100 ; 13..15: return 53 *1 ; 18: return 53 *88/100 ; 16..20: return 53 *91/100 ; 21..22: return 53 *95/100 ; return 53 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, BAC_1_11_400_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(241*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(346*5/64); // airplane climbing after take-off
      18: return int(870*5/64); // heading for tower contact point
  16..20: return int(451*5/64); // in flight
  21..22: return int(225*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, BAC_1_11_400_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, BAC_1_11_400_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_BAC);
  1: string(STR_VLIV_AMERICAN_AIRLINES);
  2: string(STR_VLIV_BRITISH_AIRWAYS_NEGUS);
  3: string(STR_VLIV_TAE);
  4: string(STR_VLIV_TAROM);
     return CB_RESULT_NO_TEXT;
}

item (FEAT_AIRCRAFT, BAC_1_11_400)
{
  property
  {
    name: string(STR_AIRV_BAC_1_11_400);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1964 - 2, 1, 1);
    vehicle_life: 12;
    model_life: 1989 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1964 -1989 -2 < retire_early_default ? 1989 -1964 +2 : -retire_early_default);
    retire_early: 1964 -1989 -2 < retire_early_default ? retire_early_default+1 : 1964 -1989 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 16;
    passenger_capacity: 89;
    mail_capacity: 9;
    acceleration: 27; // in 27,75 mph/day
    range: 635;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: BAC_1_11_400_sprites;
    purchase: BAC_1_11_400_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: BAC_1_11_400_cargo_subtype_text;
    speed: BAC_1_11_400_speed;
    running_cost_factor: BAC_1_11_400_running_cost_factor;
    sound_effect: BAC_1_11_400_sound_effect;

    cost_factor: 37;
    purchase_running_cost_factor: 53;
    purchase_speed: int(870*5/64);
  }
}

