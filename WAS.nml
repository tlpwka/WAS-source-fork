}

item (FEAT_AIRCRAFT , Airbus_A320neo)
{
  property
  {
    name: string(STR_AIRV_AIRBUS_A320NEO);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(2016 - 2, 1, 25);
    vehicle_life: 26;
    model_life: 2099 >= 2050 ? VEHICLE_NEVER_EXPIRES : (2016 -2099 -2 < retire_early_default ? 2099 -2016 +2 : -retire_early_default);
    retire_early: 2016 -2099 -2 < retire_early_default ? retire_early_default+1 : 2016 -2099 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 22;
    passenger_capacity: 165;
    mail_capacity: 17;
    acceleration: 27; // in 27,75 mph/day
    range: 1165;
  }
  graphics {
    default: Airbus_A320neo_sprites;
    purchase: Airbus_A320neo_purchase_sprite;

    cargo_subtype_text: Airbus_A320neo_cargo_subtype_text;
 passenger_capacity: Airbus_A320neo_cargo_subtype_capacity;
    speed: Airbus_A320neo_speed;
    running_cost_factor: Airbus_A320neo_running_cost_factor;

    cost_factor: 101;
    purchase_running_cost_factor: 71;
    purchase_speed: int(833*5/64);
  }
}

if (Ranges == 0)
