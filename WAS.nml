{
  0: string(STR_VLIV_BOEING);
  1: string(STR_VLIV_BA_WORLD_CARGO);
  2: string(STR_VLIV_CARGOLUX);
     return CB_RESULT_NO_TEXT;
}

item (FEAT_AIRCRAFT, Boeing_747_8F)
{
  property
  {
    name: string(STR_AIRV_BOEING_747_8F);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(2011 - 2, 1, 1);
    vehicle_life: 40;
    model_life: 2099 >= 2050 ? VEHICLE_NEVER_EXPIRES : (2011 -2099 -2 < retire_early_default ? 2099 -2011 +2 : -retire_early_default);
    retire_early: 2011 -2099 -2 < retire_early_default ? retire_early_default+1 : 2011 -2099 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC, AIRCRAFT_FLAG_AUTOREFIT);
cargo_allow_refit: [COAL, MAIL, OIL_, LVST, GOOD, GRAI, WOOD, IORE, STEL, VALU, PAPR, WHEA, FOOD, GOLD, RUBR, FRUT, MAIZ, CORE, WATR, DIAM, SUGR, TOYS, BATT, SWET, TOFF, COLA, CTCD, BUBL, PLST, FZDR, AORE, BEER, BDMT, BRCK, CERA, CERE, CLAY, CMNT, COPR, DYES, ENSP, FERT, FICR, FISH, FMSP, FRVG, GLAS, GRVL, JAVA, LIME, MILK, MNSP, OLSD, PETR, PLAS, POTA, RCYC, RFPR, SAND, SCMT, SGBT, SGCN, SULP, VEHI, WDPR, WOOL]; cargo_disallow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 20;
    passenger_capacity: 0;
    mail_capacity: 0;
    acceleration: 27; // in 27,75 mph/day
    range: 1490;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Boeing_747_8F_sprites;
    purchase: Boeing_747_8F_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Boeing_747_8F_cargo_subtype_text;
    speed: Boeing_747_8F_speed;
    running_cost_factor: Boeing_747_8F_running_cost_factor;
    sound_effect: Boeing_747_8F_sound_effect;
    mail_capacity: return 1120;

    cost_factor: 322;
    purchase_running_cost_factor: 349;
    purchase_speed: int(1007*5/64);
  }
}

