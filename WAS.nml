switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ700_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 45 *50/100 ; 13..15: return 45 *1 ; 18: return 45 *88/100 ; 16..20: return 45 *91/100 ; 21..22: return 45 *95/100 ; return 45 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ700_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(249*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(386*5/64); // airplane climbing after take-off
      18: return int(830*5/64); // heading for tower contact point
  16..20: return int(322*5/64); // in flight
  21..22: return int(249*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

