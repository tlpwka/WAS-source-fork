item (FEAT_AIRCRAFT, Boeing_727_100)
{
  property
  {
    name: string(STR_AIRV_BOEING_727_100);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1963 - 2, 1, 1);
    vehicle_life: 20;
    model_life: 1984 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1963 -1984 -2 < retire_early_default ? 1984 -1963 +2 : -retire_early_default);
    retire_early: 1963 -1984 -2 < retire_early_default ? retire_early_default+1 : 1963 -1984 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 16;
    passenger_capacity: 131;
    mail_capacity: 15;
    acceleration: 27; // in 27,75 mph/day
    range: 950;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Boeing_727_100_sprites;
    purchase: Boeing_727_100_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Boeing_727_100_cargo_subtype_text;
 passenger_capacity: Boeing_727_100_cargo_subtype_capacity;
    speed: Boeing_727_100_speed;
    running_cost_factor: Boeing_727_100_running_cost_factor;

    cost_factor: 35;
    purchase_running_cost_factor: 95;
    purchase_speed: int(999*5/64);
  }
}

