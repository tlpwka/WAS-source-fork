  1: return 120; // Air Dolomiti
  2: return 122; // Air Europa
  3: return 122; // Air Europa Old
  4: return 120; // Austrian
  5: return 107; // Belavia
  6: return 118; // Flybe
  7: return 118; // GreatDane
  8: return 112; // LOT
  9: return 112; // Lufthansa
 10: return 116; // Montenegro
     return 118;
}

item (FEAT_AIRCRAFT, Embraer_E195LR)
{
  property
  {
    name: string(STR_AIRV_EMBRAER_ERJ_195LR);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(2005 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 2259 >= 2050 ? VEHICLE_NEVER_EXPIRES : (2005 -2259 -2 < retire_early_default ? 2259 -2005 +2 : -retire_early_default);
    retire_early: 2005 -2259 -2 < retire_early_default ? retire_early_default+1 : 2005 -2259 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 18;
    passenger_capacity: 118;
    mail_capacity: 12;
    acceleration: 27; // in 27,75 mph/day
    range: 600;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Embraer_E195LR_sprites;
    purchase: Embraer_E195LR_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Embraer_E195LR_cargo_subtype_text;
 passenger_capacity: Embraer_E195LR_cargo_subtype_capacity;
    speed: Embraer_E195LR_speed;
    running_cost_factor: Embraer_E195LR_running_cost_factor;
    sound_effect: Embraer_E195LR_sound_effect;

    cost_factor: 37;
    purchase_running_cost_factor: 66;
    purchase_speed: int(886*5/64);
  }
}

