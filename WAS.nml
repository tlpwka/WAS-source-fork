}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ100LR_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 31 *50/100 ; 13..15: return 31 *1 ; 18: return 31 *88/100 ; 16..20: return 31 *91/100 ; 21..22: return 31 *95/100 ; return 31 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ100LR_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(249*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(386*5/64); // airplane climbing after take-off
      18: return int(814*5/64); // heading for tower contact point
  16..20: return int(322*5/64); // in flight
  21..22: return int(217*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ100LR_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ100LR_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_BOMBARDIER);
  1: string(STR_VLIV_ADRIA_AIRWAYS);
  2: string(STR_VLIV_BRITAIR);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ100LR_cargo_subtype_capacity, cargo_subtype)
{
  1: return 48;
  2: return 50;
     return 50;
}

item (FEAT_AIRCRAFT, Bombardier_CRJ100LR)
{
  property
  {
    name: string(STR_AIRV_BOMBARDIER_CRJ100LR);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1992 - 2, 1, 1);
    vehicle_life: 25;
    model_life: 2010 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1992 -2010 -2 < retire_early_default ? 2010 -1992 +2 : -retire_early_default);
    retire_early: 1992 -2010 -2 < retire_early_default ? retire_early_default+1 : 1992 -2010 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 17;
    passenger_capacity: 50;
    mail_capacity: 5;
    acceleration: 27; // in 27,75 mph/day
    range: 670;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Bombardier_CRJ100LR_sprites;
    purchase: Bombardier_CRJ100LR_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Bombardier_CRJ100LR_cargo_subtype_text;
 passenger_capacity: Bombardier_CRJ100LR_cargo_subtype_capacity;
    speed: Bombardier_CRJ100LR_speed;
    running_cost_factor: Bombardier_CRJ100LR_running_cost_factor;
    sound_effect: Bombardier_CRJ100LR_sound_effect;

    cost_factor: 25;
    purchase_running_cost_factor: 31;
    purchase_speed: int(814*5/64);
  }
}

if (Ranges == 0)
{
  item (FEAT_AIRCRAFT, Bombardier_CRJ100LR)
  {
    property
    { range: 0; }
  }
}

if (Ranges == 1)
{
  item (FEAT_AIRCRAFT, Bombardier_CRJ100LR)
  {
    property
    { range: 670; }
  }
}

if (Ranges == 2)
{
  item (FEAT_AIRCRAFT, Bombardier_CRJ100LR)
  {
    property
    { range: 1000; }
  }
}
