switch (FEAT_AIRCRAFT, SELF, Boeing_747_100_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 281 *50/100 ; 13..15: return 281 *1 ; 18: return 281 *88/100 ; 16..20: return 281 *91/100 ; 21..22: return 281 *95/100 ; return 281 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_747_100_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(273*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(418*5/64); // airplane climbing after take-off
      18: return int(967*5/64); // heading for tower contact point
  16..20: return int(451*5/64); // in flight
