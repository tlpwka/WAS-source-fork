{
  8..12: return 349 *50/100 ; 13..15: return 349 *1 ; 18: return 349 *88/100 ; 16..20: return 349 *91/100 ; 21..22: return 349 *95/100 ; return 349 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_747_8F_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(289*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(451*5/64); // airplane climbing after take-off
      18: return int(1007*5/64); // heading for tower contact point
  16..20: return int(475*5/64); // in flight
  21..22: return int(289*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Boeing_747_8F_sprites, cargo_subtype)
