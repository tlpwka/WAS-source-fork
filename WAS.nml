}

item (FEAT_AIRCRAFT, SUD_CARAVELLE_III)
{
  property
  {
    name: string(STR_AIRV_SUD_CARAVELLE_III);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1958 - 2, 1, 1);
    vehicle_life: 20;
    model_life: 1972 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1958 -1972 -2 < retire_early_default ? 1972 -1958 +2 : -retire_early_default);
    retire_early: 1958 -1972 -2 < retire_early_default ? retire_early_default+1 : 1958 -1972 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 16;
    passenger_capacity: 80;
    mail_capacity: 8;
    acceleration: 27; // in 27,75 mph/day
    range: 655;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: SUD_CARAVELLE_III_sprites;
    purchase: SUD_CARAVELLE_III_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: SUD_CARAVELLE_III_cargo_subtype_text;
    speed: SUD_CARAVELLE_III_speed;
    running_cost_factor: SUD_CARAVELLE_III_running_cost_factor;
    sound_effect: SUD_CARAVELLE_III_sound_effect;

    cost_factor: 27;
    purchase_running_cost_factor: 55;
    purchase_speed: int(805*5/64);
  }
}

