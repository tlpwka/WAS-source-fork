item (FEAT_AIRCRAFT, Boeing_767_300)
{
  property
  {
    name: string(STR_AIRV_BOEING_767_300);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1986 - 2, 1, 1);
    vehicle_life: 34;
    model_life: 2020 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1986 -2020 -2 < retire_early_default ? 2020 -1986 +2 : -retire_early_default);
    retire_early: 1986 -202 -2 < retire_early_default ? retire_early_default+1 : 1986 -202 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 49;
    passenger_capacity: 269;
    mail_capacity: 27;
    acceleration: 27; // in 27,75 mph/day
    range: 1420;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Boeing_767_300_sprites;
    purchase: Boeing_767_300_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Boeing_767_300_cargo_subtype_text;
 passenger_capacity: Boeing_767_300_cargo_subtype_capacity;
    speed: Boeing_767_300_speed;
    running_cost_factor: Boeing_767_300_running_cost_factor;
    sound_effect: Boeing_767_300_sound_effect;

    cost_factor: 148;
    purchase_running_cost_factor: 121;
    purchase_speed: int(910*5/64);
  }
}

