switch (FEAT_AIRCRAFT, SELF, Airbus_A300_600F_sprites, cargo_subtype)
{
  1: Airbus_A300_600F_FedEx;
  2: Airbus_A300_600F_KoreanCargo;
  3: Airbus_A300_600F_QatarCargo;
  4: Airbus_A300_600F_UPS;
     Airbus_A300_600F_Greyscale;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A300_600F_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 128 *50/100 ; 13..15: return 128 *1 ; 18: return 128 *88/100 ; 16..20: return 128 *91/100 ; 21..22: return 128 *95/100 ; return 128 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A300_600F_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(249*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(354*5/64); // airplane climbing after take-off
      18: return int(870*5/64); // heading for tower contact point
  16..20: return int(338*5/64); // in flight
  21..22: return int(233*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A300_600F_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_AIRBUS);
  1: string(STR_VLIV_FEDEX);
  2: string(STR_VLIV_KOREAN_AIR_CARGO);
  3: string(STR_VLIV_QATAR_AIRWAYS_CARGO);
  4: string(STR_VLIV_UPS);
     return CB_RESULT_NO_TEXT;
}

item (FEAT_AIRCRAFT, Airbus_A300_600F)
{
  property
  {
    name: string(STR_AIRV_AIRBUS_A300_600F);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1994 - 2, 7, 1);
    vehicle_life: 35;
    model_life: 2009 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1994 -2009 -2 < retire_early_default ? 2009 -1994 +2 : -retire_early_default);
    retire_early: 1994 -2009 -2 < retire_early_default ? retire_early_default+1 : 1994 -2009 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC, AIRCRAFT_FLAG_AUTOREFIT);
cargo_allow_refit: [COAL, MAIL, OIL_, LVST, GOOD, GRAI, WOOD, IORE, STEL, VALU, PAPR, WHEA, FOOD, GOLD, RUBR, FRUT, MAIZ, CORE, WATR, DIAM, SUGR, TOYS, BATT, SWET, TOFF, COLA, CTCD, BUBL, PLST, FZDR, AORE, BEER, BDMT, BRCK, CERA, CERE, CLAY, CMNT, COPR, DYES, ENSP, FERT, FICR, FISH, FMSP, FRVG, GLAS, GRVL, JAVA, LIME, MILK, MNSP, OLSD, PETR, PLAS, POTA, RCYC, RFPR, SAND, SCMT, SGBT, SGCN, SULP, VEHI, WDPR, WOOL]; cargo_disallow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 20;
    passenger_capacity: 0;
    mail_capacity: 0;
    acceleration: 27; // in 27,75 mph/day
    range: 2565;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Airbus_A300_600F_sprites;
    purchase: Airbus_A300_600F_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Airbus_A300_600F_cargo_subtype_text;
    speed: Airbus_A300_600F_speed;
    running_cost_factor: Airbus_A300_600F_running_cost_factor;
 mail_capacity: return 438;

    cost_factor: 122;
    purchase_running_cost_factor: 128;
    purchase_speed: int(870*5/64);
  }
}

if (Ranges == 0)
{
  item (FEAT_AIRCRAFT, Airbus_A300_600F)
