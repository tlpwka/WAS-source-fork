switch (FEAT_AIRCRAFT, SELF, Airbus_A350_900_sprites, cargo_subtype)
{
  1: Airbus_A350_900_AirChina;
  2: Airbus_A350_900_Evelop;
  3: Airbus_A350_900_Fiji;
  4: Airbus_A350_900_Finnair;
  5: Airbus_A350_900_Iberia;
  6: Airbus_A350_900_Singapore;
 Airbus_A350_900_Greyscale;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A350_900_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 259 *50/100 ; 13..15: return 259 *1 ; 18: return 259 *88/100 ; 16..20: return 259 *91/100 ; 21..22: return 259 *95/100 ; return 259 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A350_900_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(274*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(443*5/64); // airplane climbing after take-off
      18: return int(945*5/64); // heading for tower contact point
  16..20: return int(426*5/64); // in flight
  21..22: return int(241*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A350_900_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_AIRBUS);
