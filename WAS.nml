}

switch (FEAT_AIRCRAFT, SELF, Airbus_A320_100_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 64 *50/100 ; 13..15: return 64 *1 ; 18: return 64 *88/100 ; 16..20: return 64 *91/100 ; 21..22: return 64 *95/100 ; return 64 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A320_100_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(257*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(362*5/64); // airplane climbing after take-off
      18: return int(902*5/64); // heading for tower contact point
  16..20: return int(467*5/64); // in flight
  21..22: return int(233*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A320_100_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_AIRBUS);
  1: string(STR_VLIV_AIR_FRANCE);
  2: string(STR_VLIV_AIR_INTER);
  3: string(STR_VLIV_BRITISH_AIRWAYS_UNION_FLAG);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A320_100_cargo_subtype_capacity, cargo_subtype)
{
   1: return 165; // Air France
   3: return 149; // BA
  return 150;
}

item (FEAT_AIRCRAFT, Airbus_A320_100)
{
  property
  {
    name: string(STR_AIRV_AIRBUS_A320_100);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1988 - 2, 3, 28);
    vehicle_life: 18;
    model_life: 2010 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1988 -2010 -2 < retire_early_default ? 2010 -1988 +2 : -retire_early_default);
    retire_early: 1988 -2010 -2 < retire_early_default ? retire_early_default+1 : 1988 -2010 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 22;
    passenger_capacity: 150;
    mail_capacity: 18;
    acceleration: 27; // in 27,75 mph/day
    range: 980;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Airbus_A320_100_sprites;
    purchase: Airbus_A320_100_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Airbus_A320_100_cargo_subtype_text;
 passenger_capacity: Airbus_A320_100_cargo_subtype_capacity;
    speed: Airbus_A320_100_speed;
    running_cost_factor: Airbus_A320_100_running_cost_factor;

    cost_factor: 71;
    purchase_running_cost_factor: 64;
    purchase_speed: int(902*5/64);
  }
}

if (Ranges == 0)
{
  item (FEAT_AIRCRAFT, Airbus_A320_100)
  {
    property
    { range: 0; }
  }
}

if (Ranges == 1)
{
  item (FEAT_AIRCRAFT, Airbus_A320_100)
  {
    property
    { range: 980; }
  }
}

if (Ranges == 2)
{
