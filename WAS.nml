item (FEAT_AIRCRAFT, Airbus_A310_300)
{
  property
  {
    name: string(STR_AIRV_AIRBUS_A310_300);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1985 - 2, 1, 1);
    vehicle_life: 32;
    model_life: 1998 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1985 -1998 -2 < retire_early_default ? 1998 -1985 +2 : -retire_early_default);
    retire_early: 1985 -1998 -2 < retire_early_default ? retire_early_default+1 : 1985 -1998 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 50;
    passenger_capacity: 218;
    mail_capacity: 28;
    acceleration: 27; // in 27,75 mph/day
    range: 1965;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Airbus_A310_300_sprites;
    purchase: Airbus_A310_300_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Airbus_A310_300_cargo_subtype_text;
 passenger_capacity: Airbus_A310_300_cargo_subtype_capacity;
    speed: Airbus_A310_300_speed;
    running_cost_factor: Airbus_A310_300_running_cost_factor;
    sound_effect: Airbus_A310_300_sound_effect;

    cost_factor: 137;
    purchase_running_cost_factor: 117;
    purchase_speed: int(902*5/64);
  }
}

