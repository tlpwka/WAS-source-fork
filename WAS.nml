item (FEAT_AIRCRAFT, Boeing_737_500)
{
  property
  {
    name: string(STR_AIRV_BOEING_737_500);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1990 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 2000 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1990 -2000 -2 < retire_early_default ? 2000 -1990 +2 : -retire_early_default);
    retire_early: 1990 -2000 -2 < retire_early_default ? retire_early_default+1 : 1990 -2000 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 18;
    passenger_capacity: 108;
    mail_capacity: 12;
    acceleration: 27; // in 27,75 mph/day
    range: 800;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Boeing_737_500_sprites;
    purchase: Boeing_737_500_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Boeing_737_500_cargo_subtype_text;
 passenger_capacity: Boeing_737_500_cargo_subtype_capacity;
    speed: Boeing_737_500_speed;
    running_cost_factor: Boeing_737_500_running_cost_factor;
    sound_effect: Boeing_737_500_sound_effect;

    cost_factor: 53;
    purchase_running_cost_factor: 75;
    purchase_speed: int(910*5/64);
  }
}

