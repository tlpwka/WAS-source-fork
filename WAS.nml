  8: string(STR_VLIV_SWISS_INTERNATIONAL_AIRLINES);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A321_100_cargo_subtype_capacity, cargo_subtype)
{
   1: return 212;
   2: return 186;
   3: return 200;
   4: return 200;
   5: return 190;
   6: return 190;
   7: return 220;
   8: return 176;
  return 185;
}

item (FEAT_AIRCRAFT, Airbus_A321_100)
{
  property
  {
    name: string(STR_AIRV_AIRBUS_A321_100);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1994 - 2, 1, 1);
    vehicle_life: 25;
    model_life: 2099 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1994 -2099 -2 < retire_early_default ? 2099 -1994 +2 : -retire_early_default);
    retire_early: 1994 -2099 -2 < retire_early_default ? retire_early_default+1 : 1994 -2099 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 32;
    passenger_capacity: 185;
    mail_capacity: 22;
    acceleration: 27; // in 27,75 mph/day
    range: 785;
  }
