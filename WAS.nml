switch (FEAT_AIRCRAFT, SELF, Airbus_A310_200_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 127 *50/100 ; 13..15: return 127 *1 ; 18: return 127 *88/100 ; 16..20: return 127 *91/100 ; 21..22: return 127 *95/100 ; return 127 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A310_200_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(249*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(354*5/64); // airplane climbing after take-off
      18: return int(902*5/64); // heading for tower contact point
  16..20: return int(338*5/64); // in flight
  21..22: return int(233*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A310_200_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

