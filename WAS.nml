{
  0: string(STR_VLIV_ATR);
  1: string(STR_VLIV_FARNAIR_EUROPE);
  2: string(STR_VLIV_FEDEX);
     return CB_RESULT_NO_TEXT;
}

item (FEAT_AIRCRAFT, ATR_72_200F)
{
  property
  {
    name: string(STR_AIRV_ATR_72_200F);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1991 - 2, 1, 1);
    vehicle_life: 11;
    model_life: 2099 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1991 -2099 -2 < retire_early_default ? 2099 -1991 +2 : -retire_early_default);
    retire_early: 1991 -2099 -2 < retire_early_default ? retire_early_default+1 : 1991 -2099 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC, AIRCRAFT_FLAG_AUTOREFIT);
cargo_allow_refit: [COAL, MAIL, OIL_, LVST, GOOD, GRAI, WOOD, IORE, STEL, VALU, PAPR, WHEA, FOOD, GOLD, RUBR, FRUT, MAIZ, CORE, WATR, DIAM, SUGR, TOYS, BATT, SWET, TOFF, COLA, CTCD, BUBL, PLST, FZDR, AORE, BEER, BDMT, BRCK, CERA, CERE, CLAY, CMNT, COPR, DYES, ENSP, FERT, FICR, FISH, FMSP, FRVG, GLAS, GRVL, JAVA, LIME, MILK, MNSP, OLSD, PETR, PLAS, POTA, RCYC, RFPR, SAND, SCMT, SGBT, SGCN, SULP, VEHI, WDPR, WOOL]; cargo_disallow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 5;
    passenger_capacity: 0;
    mail_capacity: 66;
    acceleration: 27; // in 27,75 mph/day
    range: 290;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: ATR_72_200F_sprites;
    purchase: ATR_72_200F_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: ATR_72_200F_cargo_subtype_text;
    speed: ATR_72_200F_speed;
    running_cost_factor: ATR_72_200F_running_cost_factor;
    sound_effect: ATR_72_200F_sound_effect;

    cost_factor: 19;
    purchase_running_cost_factor: 39;
    purchase_speed: int(523*5/64);
  }
}

