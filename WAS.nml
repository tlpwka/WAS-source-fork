switch (FEAT_AIRCRAFT, SELF, Boeing_737_600_sprites, cargo_subtype)
{
  1: Boeing_737_600_AirAlgerie;
  2: Boeing_737_600_AirEuropa;
  3: Boeing_737_600_Austrian;
  4: Boeing_737_600_Malev;
  5: Boeing_737_600_SAS;
  6: Boeing_737_600_Westjet;
    Boeing_737_600_Greyscale;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_737_600_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 74 *50/100 ; 13..15: return 74 *1 ; 18: return 74 *88/100 ; 16..20: return 74 *91/100 ; 21..22: return 74 *95/100 ; return 74 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_737_600_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(249*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(410*5/64); // airplane climbing after take-off
      18: return int(959*5/64); // heading for tower contact point
  16..20: return int(467*5/64); // in flight
  21..22: return int(233*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Boeing_737_600_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

