switch (FEAT_AIRCRAFT, SELF, Airbus_A320neo_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 73 *50/100 ; 13..15: return 73 *1 ; 18: return 73 *88/100 ; 16..20: return 73 *91/100 ; 21..22: return 73 *95/100 ; return 73 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A320neo_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(257*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(362*5/64); // airplane climbing after take-off
      18: return int(833*5/64); // heading for tower contact point
  16..20: return int(467*5/64); // in flight
  21..22: return int(244*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

