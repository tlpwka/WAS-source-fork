switch (FEAT_AIRCRAFT, SELF, Fokker_F70_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 46 *50/100 ; 13..15: return 46 *1 ; 18: return 46 *88/100 ; 16..20: return 46 *91/100 ; 21..22: return 46 *95/100 ; return 46 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Fokker_F70_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(241*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(378*5/64); // airplane climbing after take-off
      18: return int(838*5/64); // heading for tower contact point
  16..20: return int(427*5/64); // in flight
  21..22: return int(257*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Fokker_F70_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, Fokker_F70_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_FOKKER);
  1: string(STR_VLIV_ALLIANCE_AIRLINES);
  2: string(STR_VLIV_AUSTRIAN_AIRLINES);
  3: string(STR_VLIV_BMI_OLD);
  4: string(STR_VLIV_KLM);
  5: string(STR_VLIV_MALEV);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Fokker_F70_cargo_subtype_capacity, cargo_subtype)
{
   1: return 80;
   2: return 80;
   4: return 80;
   5: return 72;
  return 79;
}

item (FEAT_AIRCRAFT, Fokker_F70)
{
  property
  {
    name: string(STR_AIRV_FOKKER_70);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1992 - 2, 1, 1);
    vehicle_life: 25;
    model_life: 1997 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1992 -1997 -2 < retire_early_default ? 1997 -1992 +2 : -retire_early_default);
    retire_early: 1992 -1997 -2 < retire_early_default ? retire_early_default+1 : 1992 -1997 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 16;
    passenger_capacity: 79;
    mail_capacity: 8;
    acceleration: 27; // in 27,75 mph/day
    range: 615;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Fokker_F70_sprites;
    purchase: Fokker_F70_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Fokker_F70_cargo_subtype_text;
 passenger_capacity: Fokker_F70_cargo_subtype_capacity;
    speed: Fokker_F70_speed;
    running_cost_factor: Fokker_F70_running_cost_factor;
    sound_effect: Fokker_F70_sound_effect;

    cost_factor: 18;
    purchase_running_cost_factor: 46;
    purchase_speed: int(838*5/64);
  }
}

