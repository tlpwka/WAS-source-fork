  21: Airbus_A340_500_Singapore_Landing;
  22: Airbus_A340_500_Singapore_Touchdown;
      Airbus_A340_500_Singapore_Grounded;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A340_500_sprites, cargo_subtype)
{
  1: Airbus_A340_500_AirCanada;
  2: Airbus_A340_500_Emirates;
  3: Airbus_A340_500_Singapore;
 Airbus_A340_500_Greyscale;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A340_500_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 201 *50/100 ; 13..15: return 201 *1 ; 18: return 201 *88/100 ; 16..20: return 201 *91/100 ; 21..22: return 201 *95/100 ; return 201 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A340_500_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(281*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(483*5/64); // airplane climbing after take-off
      18: return int(918*5/64); // heading for tower contact point
  16..20: return int(443*5/64); // in flight
  21..22: return int(241*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A340_500_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A340_500_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_AIRBUS);
  1: string(STR_VLIV_AIR_CANADA);
  2: string(STR_VLIV_EMIRATES);
  3: string(STR_VLIV_SINGAPORE_AIRLINES);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A340_500_cargo_subtype_capacity, cargo_subtype)
{
   1: return 267;
   2: return 258;
   3: return 100;
  return 313;
}

item (FEAT_AIRCRAFT, Airbus_A340_500)
{
  property
  {
    name: string(STR_AIRV_AIRBUS_A340_500);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(2002 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 2099 >= 2050 ? VEHICLE_NEVER_EXPIRES : (2002 -2099 -2 < retire_early_default ? 2099 -2002 +2 : -retire_early_default);
    retire_early: 2002 -2099 -2 < retire_early_default ? retire_early_default+1 : 2002 -2099 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 42;
    passenger_capacity: 313;
    mail_capacity: 38;
    acceleration: 27; // in 27,75 mph/day
    range: 3000;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Airbus_A340_500_sprites;
    purchase: Airbus_A340_500_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Airbus_A340_500_cargo_subtype_text;
 passenger_capacity: Airbus_A340_500_cargo_subtype_capacity;
    speed: Airbus_A340_500_speed;
    running_cost_factor: Airbus_A340_500_running_cost_factor;
    sound_effect: Airbus_A340_500_sound_effect;

    cost_factor: 200;
    purchase_running_cost_factor: 201;
    purchase_speed: int(902*5/64);
  }
}

