item (FEAT_AIRCRAFT, Boeing_777_200)
{
  property
  {
    name: string(STR_AIRV_BOEING_777_200);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1995 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 2099 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1995 -2099 -2 < retire_early_default ? 2099 -1995 +2 : -retire_early_default);
    retire_early: 1995 -2099 -2 < retire_early_default ? retire_early_default+1 : 1995 -2099 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 26;
    passenger_capacity: 400;
    mail_capacity: 40;
    acceleration: 27; // in 27,75 mph/day
    range: 1745;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Boeing_777_200_sprites;
    purchase: Boeing_777_200_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Boeing_777_200_cargo_subtype_text;
 passenger_capacity: Boeing_777_200_cargo_subtype_capacity;
    speed: Boeing_777_200_speed;
    running_cost_factor: Boeing_777_200_running_cost_factor;
    sound_effect: Boeing_777_200_sound_effect;

    cost_factor: 241;
    purchase_running_cost_factor: 189;
    purchase_speed: int(951*5/64);
  }
}

