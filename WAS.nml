  4: string(STR_VLIV_IBERIA);
  5: string(STR_VLIV_ONUR_AIR);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, McDonnell_Douglas_MD88_cargo_subtype_capacity, cargo_subtype)
{
  1: return 166;
  2: return 155;
  3: return 149;
  4: return 150;
  5: return 165;
