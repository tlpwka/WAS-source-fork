switch (FEAT_AIRCRAFT, SELF, Airbus_A320_200_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 77 *50/100 ; 13..15: return 77 *1 ; 18: return 77 *88/100 ; 16..20: return 77 *91/100 ; 21..22: return 77 *95/100 ; return 77 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A320_200_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(257*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(362*5/64); // airplane climbing after take-off
      18: return int(902*5/64); // heading for tower contact point
  16..20: return int(467*5/64); // in flight
  21..22: return int(233*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

