item (FEAT_AIRCRAFT, Bombardier_CRJ700ER)
{
  property
  {
    name: string(STR_AIRV_BOMBARDIER_CRJ700ER);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1997 - 2, 1, 1);
    vehicle_life: 25;
    model_life: 2020 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1997 -2020 -2 < retire_early_default ? 2020 -1997 +2 : -retire_early_default);
    retire_early: 1997 -2020 -2 < retire_early_default ? retire_early_default+1 : 1997 -2020 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 16;
    passenger_capacity: 70;
    mail_capacity: 8;
    acceleration: 27; // in 27,75 mph/day
    range: 500;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Bombardier_CRJ700ER_sprites;
    purchase: Bombardier_CRJ700ER_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Bombardier_CRJ700ER_cargo_subtype_text;
 passenger_capacity: Bombardier_CRJ700ER_cargo_subtype_capacity;
    speed: Bombardier_CRJ700ER_speed;
    running_cost_factor: Bombardier_CRJ700ER_running_cost_factor;
    sound_effect: Bombardier_CRJ700ER_sound_effect;

    cost_factor: 24;
    purchase_running_cost_factor: 41;
    purchase_speed: int(830*5/64);
  }
}

