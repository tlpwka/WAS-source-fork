item (FEAT_AIRCRAFT, Boeing_767_200)
{
  property
  {
    name: string(STR_AIRV_BOEING_767_200);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1981 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 1994 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1981 -1994 -2 < retire_early_default ? 1994 -1981 +2 : -retire_early_default);
    retire_early: 1981 -1994 -2 < retire_early_default ? retire_early_default+1 : 1981 -1994 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 32;
    passenger_capacity: 181;
    mail_capacity: 22;
    acceleration: 27; // in 27,75 mph/day
    range: 1285;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Boeing_767_200_sprites;
    purchase: Boeing_767_200_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Boeing_767_200_cargo_subtype_text;
 passenger_capacity: Boeing_767_200_cargo_subtype_capacity;
    speed: Boeing_767_200_speed;
    running_cost_factor: Boeing_767_200_running_cost_factor;
    sound_effect: Boeing_767_200_sound_effect;

    cost_factor: 127;
    purchase_running_cost_factor: 121;
    purchase_speed: int(910*5/64);
  }
}

