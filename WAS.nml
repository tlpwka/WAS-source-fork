# 0 "WAS.pnml"
# 0 "<built-in>"
# 0 "<command-line>"
# 1 "WAS.pnml"
 // WAS

# 1 "src/header.pnml" 1
 /// header

// List of source files included from main file

grf {
    grfid: "WAS2";
    name: string(STR_GRF_NAME);
    desc: string(STR_GRF_DESCRIPTION);
    url: string(STR_GRF_URL);
    version: 7876;
    min_compatible_version: 1;
  param 0 {
    enable_standard_planes {
      name: string(STR_PARAM_NAME_ENABLE_STANDARD_PLANES);
      desc: string(STR_PARAM_DESC_ENABLE_STANDARD_PLANES);
      type: bool;
      bit: 0;
      def_value: 0;
    }
  }
  param 1 {
    BCosts {
      type: int;
      name: string(STR_PARAM_BCOSTS_NAME);
      desc: string(STR_PARAM_BCOSTS_DESC);
      min_value: 0;
      max_value: 8;
      def_value: 4;
    }
  }
  param 2 {
    RCosts {
      type: int;
      name: string(STR_PARAM_RCOSTS_NAME);
      desc: string(STR_PARAM_RCOSTS_DESC);
      min_value: 0;
      max_value: 8;
      def_value: 4;
    }
  }
  param 3 {
    Ranges {
      type: int;
      name: string(STR_PARAM_NAME_RANGES);
      desc: string(STR_PARAM_DESC_RANGES);
      min_value: 0;
      max_value: 2;
      def_value: 1;
      names: {
        0: string(STR_PARAM_VALUE_RANGES_OFF);
        1: string(STR_PARAM_VALUE_RANGES_NORMAL);
        2: string(STR_PARAM_VALUE_RANGES_LONG);
      } ;
    }
  }
}
# 4 "WAS.pnml" 2
# 1 "src/check.pnml" 1
 /// check

// version check
// only for OpenTTD >= r23744
if (ttd_platform != PLATFORM_OPENTTD ||
  openttd_version < version_openttd(1, 2, 0, 23744))
{
  error(ERROR, REQUIRES_OPENTTD, string(STR_MIN_OPENTTD_VERSION));
}
# 5 "WAS.pnml" 2
# 1 "src/basecost.pnml" 1
 /// basecost

basecost
{
  PR_BUILD_VEHICLE_AIRCRAFT: BCosts-4;
  PR_RUNNING_AIRCRAFT: RCosts-4;
}
# 6 "WAS.pnml" 2
# 1 "src/cargotable.pnml" 1
 // cargotable

cargotable
{
  AORE,
  BATT, BDMT, BEER, BRCK, BUBL,
  CERA, CERE, CLAY, CMNT, COAL, WHEA, COPR, CORE, CTCD,
  DIAM, DYES,
  ENSP,
  FERT, FICR, FISH, FMSP, FOOD, FRUT, FRVG, FZDR,
  GEAR, GLAS, GOLD, GOOD, GRAI, GRVL,
  IORE,
  JAVA,
  LIME, LVST,
  MAIL, MAIZ, MILK, MNSP,
  OIL_, OLSD,
  PAPR, PASS, PETR, PLST, PLAS, POTA,
  RCYC, RFPR, RUBR, RSGR,
  SAND, SCMT, SGBT, SGCN, STEL, SUGR, SULP, SWET,
  TOFF, TOUR, TOYS,
  VALU, VEHI,
  WATR, WDPR, COLA, WOOD, WOOL
}
# 7 "WAS.pnml" 2
# 1 "src/definition.pnml" 1
 /// definition

retire_early_default = -8;





// 00: entering hangar
// 01: going to hangar entrance point
// 02: going to pad 1
// 03: going to pad 2
// 04: going to pad 3
// 05: going to pad 2 / pad 3 common entry point
// 06: going to pad 2 / pad 3 / hangar common entry point (large airports only)
// 07: going to airport's junction point (this is the location where helicopters land and take off)
// 08: leaving runway
// 09: going to the in way
// 10: entering runway
// 11: going to the out way
// 12: airplane waiting for take-off clearance (?)
// 13: airplane taking off
// 14: airplane preparing to take-off
// 15: airplane climbing after take-off
// 16..20: in flight
//     16: final approach before landing or going for another round
//     18: heading for tower contact point (where airplanes initiate their approach)
//     20: heading for the final approach entry point
// 21: airplane landing (descent)
// 22: airplane braking after touchdown
// 23: helicopter taking off from airport
// 24: helicopter preparing to land at airport
// 25: helicopter landing at airport
// 26: helicopter taking off from heliport
// 27: helicopter preparing to land at heliport
// 28: helicopter landing at heliport
# 8 "WAS.pnml" 2
# 1 "src/graph_templates.pnml" 1
 /// graphics definition

// Определение спрайта меню покупки
# 9 "WAS.pnml" 2
# 1 "src/disable_origin.pnml" 1
 /// disable_origin

// debug: disable all original planes

if (!enable_standard_planes)
{
  disable_item(FEAT_AIRCRAFT, 0, 39);
}
