switch (FEAT_AIRCRAFT, SELF, Embraer_E170LR_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 41 *50/100 ; 13..15: return 41 *1 ; 18: return 41 *88/100 ; 16..20: return 41 *91/100 ; 21..22: return 41 *95/100 ; return 41 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E170LR_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(241*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(410*5/64); // airplane climbing after take-off
      18: return int(886*5/64); // heading for tower contact point
  16..20: return int(418*5/64); // in flight
  21..22: return int(257*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E170LR_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_EMBRAER);
  1: string(STR_VLIV_ESTONIAN);
  2: string(STR_VLIV_HOP);
       return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E170LR_cargo_subtype_capacity, cargo_subtype)
{
  1: return 76;
  2: return 76;
     return 78;
}

item (FEAT_AIRCRAFT, Embraer_E170LR)
{
  property
  {
    name: string(STR_AIRV_EMBRAER_ERJ_170LR);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(2004 - 2, 3, 1);
    vehicle_life: 25;
    model_life: 2256 >= 2050 ? VEHICLE_NEVER_EXPIRES : (2004 -2256 -2 < retire_early_default ? 2256 -2004 +2 : -retire_early_default);
    retire_early: 2004 -2256 -2 < retire_early_default ? retire_early_default+1 : 2004 -2256 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 29;
    passenger_capacity: 78;
    mail_capacity: 8;
    acceleration: 27; // in 27,75 mph/day
    range: 700;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Embraer_E170LR_sprites;
    purchase: Embraer_E170LR_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Embraer_E170LR_cargo_subtype_text;
 passenger_capacity: Embraer_E170LR_cargo_subtype_capacity;
    speed: Embraer_E170LR_speed;
    running_cost_factor: Embraer_E170LR_running_cost_factor;

    cost_factor: 25;
    purchase_running_cost_factor: 41;
    purchase_speed: int(886*5/64);
  }
}

if (Ranges == 0)
{
  item (FEAT_AIRCRAFT, Embraer_E170LR)
  {
    property
    { range: 0; }
  }
}

if (Ranges == 1)
{
  item (FEAT_AIRCRAFT, Embraer_E170LR)
  {
    property
    { range: 700; }
  }
}

if (Ranges == 2)
