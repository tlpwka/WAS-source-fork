item (FEAT_AIRCRAFT, Boeing_737_300)
{
  property
  {
    name: string(STR_AIRV_BOEING_737_300);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1984 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 1994 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1984 -1994 -2 < retire_early_default ? 1994 -1984 +2 : -retire_early_default);
    retire_early: 1984 -1994 -2 < retire_early_default ? retire_early_default+1 : 1984 -1994 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 18;
    passenger_capacity: 128;
    mail_capacity: 15;
    acceleration: 27; // in 27,75 mph/day
    range: 755;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Boeing_737_300_sprites;
    purchase: Boeing_737_300_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Boeing_737_300_cargo_subtype_text;
 passenger_capacity: Boeing_737_300_cargo_subtype_capacity;
    speed: Boeing_737_300_speed;
    running_cost_factor: Boeing_737_300_running_cost_factor;
    sound_effect: Boeing_737_300_sound_effect;

    cost_factor: 29;
    purchase_running_cost_factor: 64;
    purchase_speed: int(910*5/64);
  }
}

