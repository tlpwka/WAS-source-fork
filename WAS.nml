item (FEAT_AIRCRAFT, Fokker_F100)
{
  property
  {
    name: string(STR_AIRV_FOKKER_100);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1986 - 2, 1, 1);
    vehicle_life: 25;
    model_life: 1997 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1986 -1997 -2 < retire_early_default ? 1997 -1986 +2 : -retire_early_default);
    retire_early: 1986 -1997 -2 < retire_early_default ? retire_early_default+1 : 1986 -1997 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 19;
    passenger_capacity: 107;
    mail_capacity: 11;
    acceleration: 27; // in 27,75 mph/day
    range: 570;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Fokker_F100_sprites;
    purchase: Fokker_F100_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Fokker_F100_cargo_subtype_text;
 passenger_capacity: Fokker_F100_cargo_subtype_capacity;
    speed: Fokker_F100_speed;
    running_cost_factor: Fokker_F100_running_cost_factor;
    sound_effect: Fokker_F100_sound_effect;

    cost_factor: 27;
    purchase_running_cost_factor: 61;
    purchase_speed: int(846*5/64);
  }
}

