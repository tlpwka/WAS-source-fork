}

switch (FEAT_AIRCRAFT, SELF, Douglas_DC10_30_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(346*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(523*5/64); // airplane climbing after take-off
      18: return int(983*5/64); // heading for tower contact point
  16..20: return int(467*5/64); // in flight
  21..22: return int(257*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

