switch (FEAT_AIRCRAFT, SELF, Ilyushin_62_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 42 *50/100 ; 13..15: return 42 *1 ; 18: return 42 *88/100 ; 16..20: return 42 *91/100 ; 21..22: return 42 *95/100 ; return 42 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Ilyushin_62_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(273*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(394*5/64); // airplane climbing after take-off
      18: return int(822*5/64); // heading for tower contact point
  16..20: return int(370*5/64); // in flight
  21..22: return int(233*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Ilyushin_62_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, Ilyushin_62_cargo_subtype_text, cargo_subtype)
