switch (FEAT_AIRCRAFT, SELF, SUD_CARAVELLE_III_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 55 *50/100 ; 13..15: return 55 *1 ; 18: return 55 *88/100 ; 16..20: return 55 *91/100 ; 21..22: return 55 *95/100 ; return 55 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, SUD_CARAVELLE_III_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(201*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(402*5/64); // airplane climbing after take-off
      18: return int(805*5/64); // heading for tower contact point
  16..20: return int(354*5/64); // in flight
  21..22: return int(201*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

