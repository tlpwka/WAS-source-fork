{
  8..12: return 29 *50/100 ; 13..15: return 29 *1 ; 18: return 29 *88/100 ; 16..20: return 29 *91/100 ; 21..22: return 29 *95/100 ; return 29 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E190AR_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(241*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(410*5/64); // airplane climbing after take-off
      18: return int(886*5/64); // heading for tower contact point
  16..20: return int(427*5/64); // in flight
  21..22: return int(273*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E190AR_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_EMBRAER);
  1: string(STR_VLIV_AUSTRAL_LINEAS_AEREAS);
  2: string(STR_VLIV_CONVIASA);
  3: string(STR_VLIV_COPA_AIRLINES);
  4: string(STR_VLIV_JETBLUE);
  5: string(STR_VLIV_PEGAS_FLY);
  6: string(STR_VLIV_UKRAINE_INTERNATIONAL_AIRLINES);
  7: string(STR_VLIV_VIRGIN_BLUE);
       return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Embraer_E190AR_cargo_subtype_capacity, cargo_subtype)
{
  1: return 96; // Austral
  2: return 104; // Conviasa
  3: return 94; // Copa
  4: return 100; // JetBlue
  5: return 110; // PegasFly
  6: return 118; // TAP
  7: return 104; // Ukraine
  8: return 92; // Virgin Blue
     return 106;
}

item (FEAT_AIRCRAFT, Embraer_E190AR)
{
  property
  {
    name: string(STR_AIRV_EMBRAER_ERJ_190AR);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(2004 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 2259 >= 2050 ? VEHICLE_NEVER_EXPIRES : (2004 -2259 -2 < retire_early_default ? 2259 -2004 +2 : -retire_early_default);
    retire_early: 2004 -2259 -2 < retire_early_default ? retire_early_default+1 : 2004 -2259 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 19;
    passenger_capacity: 106;
    mail_capacity: 11;
    acceleration: 27; // in 27,75 mph/day
    range: 800;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Embraer_E190AR_sprites;
    purchase: Embraer_E190AR_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Embraer_E190AR_cargo_subtype_text;
 passenger_capacity: Embraer_E190AR_cargo_subtype_capacity;
    speed: Embraer_E190AR_speed;
    running_cost_factor: Embraer_E190AR_running_cost_factor;

    cost_factor: 59;
    purchase_running_cost_factor: 29;
    purchase_speed: int(886*5/64);
  }
}

