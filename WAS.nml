  property
  {
    name: string(STR_AIRV_BOEING_737_800);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1998 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 2253 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1998 -2253 -2 < retire_early_default ? 2253 -1998 +2 : -retire_early_default);
    retire_early: 1998 -2253 -2 < retire_early_default ? retire_early_default+1 : 1998 -2253 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
