}

switch (FEAT_AIRCRAFT, SELF, ATR_72_200_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 39 *50/100 ; 13..15: return 39 *1 ; 18: return 39 *88/100 ; 16..20: return 39 *91/100 ; 21..22: return 39 *95/100 ; return 39 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, ATR_72_200_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(257*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(346*5/64); // airplane climbing after take-off
      18: return int(515*5/64); // heading for tower contact point
  16..20: return int(362*5/64); // in flight
  21..22: return int(217*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, ATR_72_200_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, ATR_72_200_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_ATR);
  1: string(STR_VLIV_AER_ARRAN_ORIGINAL);
  2: string(STR_VLIV_AURIGNY_AIR_SERVICES);
  3: string(STR_VLIV_FINNAIR);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, ATR_72_200_cargo_subtype_capacity, cargo_subtype)
{
  1: return 66;
  2: return 66;
     return 74;
}

item (FEAT_AIRCRAFT, ATR_72_200)
{
  property
  {
    name: string(STR_AIRV_ATR_72_200);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1988 - 2, 1, 1);
    vehicle_life: 11;
    model_life: 2021 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1988 -2021 -2 < retire_early_default ? 2021 -1988 +2 : -retire_early_default);
    retire_early: 1988 -2021 -2 < retire_early_default ? retire_early_default+1 : 1988 -2021 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 16;
    passenger_capacity: 74;
    mail_capacity: 7;
    acceleration: 27; // in 27,75 mph/day
    range: 290;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: ATR_72_200_sprites;
    purchase: ATR_72_200_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: ATR_72_200_cargo_subtype_text;
 passenger_capacity: ATR_72_200_cargo_subtype_capacity;
    speed: ATR_72_200_speed;
    running_cost_factor: ATR_72_200_running_cost_factor;
    sound_effect: ATR_72_200_sound_effect;

    cost_factor: 16;
    purchase_running_cost_factor: 39;
    purchase_speed: int(515*5/64);
  }
}

