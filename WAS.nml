switch (FEAT_AIRCRAFT, SELF, McDonnell_Douglas_MD11F_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 250 *50/100 ; 13..15: return 250 *1 ; 18: return 250 *88/100 ; 16..20: return 250 *91/100 ; 21..22: return 250 *95/100 ; return 250 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, McDonnell_Douglas_MD11F_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(314*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(483*5/64); // airplane climbing after take-off
      18: return int(943*5/64); // heading for tower contact point
  16..20: return int(475*5/64); // in flight
  21..22: return int(281*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, McDonnell_Douglas_MD11F_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, McDonnell_Douglas_MD11F_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_MCDONNEL_DOUGLAS);
  1: string(STR_VLIV_FEDEX);
  2: string(STR_VLIV_KOREAN_AIR_CARGO);
  3: string(STR_VLIV_MARTINAIR_CARGO);
  4: string(STR_VLIV_UPS);
     return CB_RESULT_NO_TEXT;
}

item (FEAT_AIRCRAFT, McDonnell_Douglas_MD11F)
{
  property
  {
    name: string(STR_AIRV_MCDONNELL_DOUGLAS_MD_11F);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1988 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 2010 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1988 -2010 -2 < retire_early_default ? 2010 -1988 +2 : -retire_early_default);
    retire_early: 1988 -2010 -2 < retire_early_default ? retire_early_default+1 : 1988 -2010 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC, AIRCRAFT_FLAG_AUTOREFIT);
cargo_allow_refit: [COAL, MAIL, OIL_, LVST, GOOD, GRAI, WOOD, IORE, STEL, VALU, PAPR, WHEA, FOOD, GOLD, RUBR, FRUT, MAIZ, CORE, WATR, DIAM, SUGR, TOYS, BATT, SWET, TOFF, COLA, CTCD, BUBL, PLST, FZDR, AORE, BEER, BDMT, BRCK, CERA, CERE, CLAY, CMNT, COPR, DYES, ENSP, FERT, FICR, FISH, FMSP, FRVG, GLAS, GRVL, JAVA, LIME, MILK, MNSP, OLSD, PETR, PLAS, POTA, RCYC, RFPR, SAND, SCMT, SGBT, SGCN, SULP, VEHI, WDPR, WOOL]; cargo_disallow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 10;
    passenger_capacity: 0;
    mail_capacity: 0;
    acceleration: 27; // in 27,75 mph/day
    range: 1315;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: McDonnell_Douglas_MD11F_sprites;
    purchase: McDonnell_Douglas_MD11F_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: McDonnell_Douglas_MD11F_cargo_subtype_text;
    speed: McDonnell_Douglas_MD11F_speed;
    running_cost_factor: McDonnell_Douglas_MD11F_running_cost_factor;
    sound_effect: McDonnell_Douglas_MD11F_sound_effect;
    mail_capacity: return 726;

    cost_factor: 137;
    purchase_running_cost_factor: 250;
    purchase_speed: int(943*5/64);
  }
}

