item (FEAT_AIRCRAFT, Douglas_DC10_30)
{
  property
  {
    name: string(STR_AIRV_DOUGLAS_DC_10_30);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1973 - 2, 1, 1);
    vehicle_life: 25;
    model_life: 1988 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1973 -1988 -2 < retire_early_default ? 1988 -1973 +2 : -retire_early_default);
    retire_early: 1973 -1988 -2 < retire_early_default ? retire_early_default+1 : 1973 -1988 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_LARGE;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 49;
    passenger_capacity: 255;
    mail_capacity: 29;
    acceleration: 27; // in 27,75 mph/day
    range: 1910;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Douglas_DC10_30_sprites;
    purchase: Douglas_DC10_30_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Douglas_DC10_30_cargo_subtype_text;
 passenger_capacity: Douglas_DC10_30_cargo_subtype_capacity;
    speed: Douglas_DC10_30_speed;
