switch (FEAT_AIRCRAFT, SELF, Boeing_737_200C_Greyscale, (var[0xE2, 0, 0xFF]))
{
  15: Boeing_737_200C_Greyscale_Climbing;
  18: Boeing_737_200C_Greyscale_Flight;
  21: Boeing_737_200C_Greyscale_Climbing;
  22: Boeing_737_200C_Greyscale_Touchdown;
      Boeing_737_200C_Greyscale_Grounded;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_737_200C_RegionalCargo, (var[0xE2, 0, 0xFF]))
{
  15: Boeing_737_200C_RegionalCargo_Climbing;
  18: Boeing_737_200C_RegionalCargo_Flight;
  21: Boeing_737_200C_RegionalCargo_Climbing;
  22: Boeing_737_200C_RegionalCargo_Touchdown;
      Boeing_737_200C_RegionalCargo_Grounded;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_737_200C_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 60 *50/100 ; 13..15: return 60 *1 ; 18: return 60 *88/100 ; 16..20: return 60 *91/100 ; 21..22: return 60 *95/100 ; return 60 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_737_200C_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(249*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(410*5/64); // airplane climbing after take-off
      18: return int(878*5/64); // heading for tower contact point
  16..20: return int(467*5/64); // in flight
  21..22: return int(249*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Boeing_737_200C_sprites, cargo_subtype)
{
  1: Boeing_737_200C_RegionalCargo;
     Boeing_737_200C_Greyscale;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_737_200C_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, Boeing_737_200C_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_BOEING);
  1: string(STR_VLIV_REGIONAL_CARGO);
     return CB_RESULT_NO_TEXT;
}

item (FEAT_AIRCRAFT, Boeing_737_200C)
{
  property
  {
    name: string(STR_AIRV_BOEING_737_200C);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1968 - 2, 1, 1);
    vehicle_life: 45;
    model_life: 1988 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1968 -1988 -2 < retire_early_default ? 1988 -1968 +2 : -retire_early_default);
    retire_early: 1968 -1988 -2 < retire_early_default ? retire_early_default+1 : 1968 -1988 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC, AIRCRAFT_FLAG_AUTOREFIT);
cargo_allow_refit: [COAL, MAIL, OIL_, LVST, GOOD, GRAI, WOOD, IORE, STEL, VALU, PAPR, WHEA, FOOD, GOLD, RUBR, FRUT, MAIZ, CORE, WATR, DIAM, SUGR, TOYS, BATT, SWET, TOFF, COLA, CTCD, BUBL, PLST, FZDR, AORE, BEER, BDMT, BRCK, CERA, CERE, CLAY, CMNT, COPR, DYES, ENSP, FERT, FICR, FISH, FMSP, FRVG, GLAS, GRVL, JAVA, LIME, MILK, MNSP, OLSD, PETR, PLAS, POTA, RCYC, RFPR, SAND, SCMT, SGBT, SGCN, SULP, VEHI, WDPR, WOOL]; cargo_disallow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 5;
    passenger_capacity: 0;
    mail_capacity: 127;
    acceleration: 27; // in 27,75 mph/day
    range: 845;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Boeing_737_200C_sprites;
    purchase: Boeing_737_200C_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Boeing_737_200C_cargo_subtype_text;
    speed: Boeing_737_200C_speed;
    running_cost_factor: Boeing_737_200C_running_cost_factor;
    sound_effect: Boeing_737_200C_sound_effect;

    cost_factor: 37;
    purchase_running_cost_factor: 60;
    purchase_speed: int(878*5/64);
  }
}

