item (FEAT_AIRCRAFT, Douglas_DC9_50)
{
  property
  {
    name: string(STR_AIRV_DOUGLAS_DC_9_50);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1975 - 2, 1, 1);
    vehicle_life: 30;
    model_life: 1982 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1975 -1982 -2 < retire_early_default ? 1982 -1975 +2 : -retire_early_default);
    retire_early: 1975 -1982 -2 < retire_early_default ? retire_early_default+1 : 1975 -1982 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 22;
    passenger_capacity: 135;
    mail_capacity: 14;
    acceleration: 27; // in 27,75 mph/day
    range: 600;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Douglas_DC9_50_sprites;
    purchase: Douglas_DC9_50_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Douglas_DC9_50_cargo_subtype_text;
 passenger_capacity: Douglas_DC9_50_cargo_subtype_capacity;
    speed: Douglas_DC9_50_speed;
    running_cost_factor: Douglas_DC9_50_running_cost_factor;
    sound_effect: Douglas_DC9_50_sound_effect;

    cost_factor: 44;
    purchase_running_cost_factor: 65;
    purchase_speed: int(918*5/64);
  }
}

