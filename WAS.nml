{
  12..13: return int(273*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(451*5/64); // airplane climbing after take-off
      18: return int(951*5/64); // heading for tower contact point
  16..20: return int(459*5/64); // in flight
  21..22: return int(273*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

