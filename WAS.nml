    running_cost_factor: Boeing_767_300F_running_cost_factor;
    sound_effect: Boeing_767_300F_sound_effect;
    mail_capacity: return 480;

    cost_factor: 152;
    purchase_running_cost_factor: 187;
    purchase_speed: int(910*5/64);
  }
}

