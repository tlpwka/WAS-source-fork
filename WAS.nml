 10: string(STR_VLIV_TAP);
 11: string(STR_VLIV_URAL_AIRLINES);
 12: string(STR_VLIV_VUELING_AIRLINES);
 13: string(STR_VLIV_WIZZ_AIR);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Airbus_A320neo_cargo_subtype_capacity, cargo_subtype)
{
  1: return 180; // Air Malta
  2: return 180; // British
  3: return 186; // Easyjet
  4: return 180; // Iberia
  5: return 180; // Lufthansa
  6: return 186; // Pegasus
  7: return 164; // S7
  8: return 174; // SAS
  9: return 180; // Swiss
 10: return 174; // TAP
