item (FEAT_AIRCRAFT, Airbus_A321_200)
{
  property
  {
    name: string(STR_AIRV_AIRBUS_A321_200);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(1996 - 2, 12, 1);
    vehicle_life: 25;
    model_life: 2099 >= 2050 ? VEHICLE_NEVER_EXPIRES : (1996 -2099 -2 < retire_early_default ? 2099 -1996 +2 : -retire_early_default);
    retire_early: 1996 -2099 -2 < retire_early_default ? retire_early_default+1 : 1996 -2099 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 32;
    passenger_capacity: 185;
    mail_capacity: 22;
    acceleration: 27; // in 27,75 mph/day
    range: 885;
  }
  graphics {
    default: Airbus_A321_200_sprites;
    purchase: Airbus_A321_200_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Airbus_A321_200_cargo_subtype_text;
 passenger_capacity: Airbus_A321_200_cargo_subtype_capacity;
    speed: Airbus_A321_200_speed;
    running_cost_factor: Airbus_A321_200_running_cost_factor;

    cost_factor: 84;
    purchase_running_cost_factor: 87;
    purchase_speed: int(902*5/64);
  }
}

