switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ900ER_running_cost_factor, (var[0xE2, 0, 0xFF]))
{
  8..12: return 45 *50/100 ; 13..15: return 45 *1 ; 18: return 45 *88/100 ; 16..20: return 45 *91/100 ; 21..22: return 45 *95/100 ; return 45 *37/100 ;
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ900ER_speed, (var[0xE2, 0, 0xFF]))
{
  12..13: return int(249*5/64); // airplane waiting for take-off clearance, airplane taking off
      15: return int(386*5/64); // airplane climbing after take-off
      18: return int(846*5/64); // heading for tower contact point
  16..20: return int(322*5/64); // in flight
  21..22: return int(265*5/64); // airplane landing, airplane braking after touchdown
          return int(201*5/64);
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ900ER_sound_effect, extra_callback_info1)
{
  SOUND_EVENT_START : sound("src/sound/av_turbogo.wav");
  SOUND_EVENT_TOUCHDOWN : sound("src/sound/av_landturbo.wav");
                          return CB_RESULT_NO_SOUND;
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ900ER_cargo_subtype_text, cargo_subtype)
{
  0: string(STR_VLIV_BOMBARDIER);
  1: string(STR_VLIV_AIR_NOSTRUM_IBERIA_REGIONAL);
  2: string(STR_VLIV_AMERICAN_EAGLE);
  3: string(STR_VLIV_BRITAIR);
  4: string(STR_VLIV_MAT_MACEDONIAN);
     return CB_RESULT_NO_TEXT;
}

switch (FEAT_AIRCRAFT, SELF, Bombardier_CRJ900ER_cargo_subtype_capacity, cargo_subtype)
{
  1: return 90; //Air Nostrum
  2: return 76; //American Eagle
  3: return 90; //Brtiair
     return 88;
}

item (FEAT_AIRCRAFT, Bombardier_CRJ900ER)
{
  property
  {
    name: string(STR_AIRV_BOMBARDIER_CRJ900ER);
    climates_available: bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL, CLIMATE_TOYLAND);
    introduction_date: date(2007 - 2, 1, 1);
    vehicle_life: 25;
    model_life: 2099 >= 2050 ? VEHICLE_NEVER_EXPIRES : (2007 -2099 -2 < retire_early_default ? 2099 -2007 +2 : -retire_early_default);
    retire_early: 2007 -2099 -2 < retire_early_default ? retire_early_default+1 : 2007 -2099 -1;

    sprite_id: SPRITE_ID_NEW_AIRCRAFT;
    aircraft_type: AIRCRAFT_TYPE_SMALL;
    misc_flags: bitmask(AIRCRAFT_FLAG_2CC);
    cargo_allow_refit: [PASS, TOUR];
    reliability_decay: 20;
    loading_speed: 16;
    passenger_capacity: 88;
    mail_capacity: 9;
    acceleration: 27; // in 27,75 mph/day
    range: 430;
    sound_effect: SOUND_JET;
  }
  graphics {
    default: Bombardier_CRJ900ER_sprites;
    purchase: Bombardier_CRJ900ER_purchase_sprite;
    colour_mapping: PALETTE_CC_FIRST;

    cargo_subtype_text: Bombardier_CRJ900ER_cargo_subtype_text;
 passenger_capacity: Bombardier_CRJ900ER_cargo_subtype_capacity;
    speed: Bombardier_CRJ900ER_speed;
    running_cost_factor: Bombardier_CRJ900ER_running_cost_factor;
    sound_effect: Bombardier_CRJ900ER_sound_effect;

    cost_factor: 28;
    purchase_running_cost_factor: 45;
    purchase_speed: int(846*5/64);
  }
}

if (Ranges == 0)
{
  item (FEAT_AIRCRAFT, Bombardier_CRJ900ER)
  {
    property
    { range: 0; }
  }
}

if (Ranges == 1)
{
  item (FEAT_AIRCRAFT, Bombardier_CRJ900ER)
  {
    property
    { range: 430; }
  }
}

if (Ranges == 2)
{
  item (FEAT_AIRCRAFT, Bombardier_CRJ900ER)
  {
    property
    { range: 640; }
  }
}
